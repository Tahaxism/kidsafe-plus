# Copy to .env locally; set the same vars in Render's dashboard for production.

# Required: OpenAI key — used for assistant chat, classifier and Whisper.
OPENAI_API_KEY=sk-...

# Optional: Firebase Admin credentials (base64-encoded service-account JSON).
# Set these to enable verifying mobile-side Firebase ID tokens and sending
# push notifications via FCM. Leave blank for development.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Server config
PORT=8787
NODE_ENV=development

# Allowed CORS origins (comma-separated). Use "*" for development.
CORS_ORIGINS=*

# Rate limiting (per IP per minute)
RATE_LIMIT_PER_MIN=60
